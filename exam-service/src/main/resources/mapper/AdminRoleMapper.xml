<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.jack.exam.mapper.AdminRoleMapper">

    <select id="findByUserId" resultType="cn.jack.exam.entity.AdminRole">
        select r.id,
               r.role_code,
               r.role_name
        from admin_role r
        inner join admin_user_role ur on ur.role_id = r.id
        where ur.user_id = #{userId}
    </select>
</mapper>
