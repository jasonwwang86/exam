<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.jack.exam.mapper.ExamineeMapper">

    <sql id="BaseFilter">
        deleted = 0
        <if test="keyword != null and keyword != ''">
            and (
                examinee_no like concat('%', #{keyword}, '%')
                or name like concat('%', #{keyword}, '%')
                or phone like concat('%', #{keyword}, '%')
            )
        </if>
        <if test="status != null and status != ''">
            and status = #{status}
        </if>
    </sql>

    <select id="findPage" resultType="cn.jack.exam.dto.examinee.ExamineeListItemResponse">
        select id,
               examinee_no,
               name,
               gender,
               id_card_no,
               phone,
               email,
               status,
               remark,
               updated_at
        from examinee
        where <include refid="BaseFilter"/>
        order by id asc
        limit #{pageSize} offset #{offset}
    </select>

    <select id="countPage" resultType="long">
        select count(1)
        from examinee
        where <include refid="BaseFilter"/>
    </select>

    <select id="findForExport" resultType="cn.jack.exam.entity.Examinee">
        select id,
               examinee_no,
               name,
               gender,
               id_card_no,
               phone,
               email,
               status,
               remark,
               deleted,
               created_at,
               updated_at
        from examinee
        where <include refid="BaseFilter"/>
        order by id asc
    </select>
</mapper>
